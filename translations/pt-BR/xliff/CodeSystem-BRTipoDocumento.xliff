      <trans-unit id="CodeSystem-BRTipoDocumento" resname="CodeSystem.concept.definition">
             <notes>
               <note id="n1">CodeSystem.concept.definition</note>
             </notes>
        <source>Documento público que coleta os dados mínimos dos atendimentos em saúde realizados em qualquer estabelecimento de saúde do país, público ou privado, em cada contato assistencial.</source>
        <target></target>
      </trans-unit>
