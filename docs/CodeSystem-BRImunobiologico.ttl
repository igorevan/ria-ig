3 (inativada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">23<a name=\"BRImunobiologico-23\"> </a></td><td>IGHAR</td><td>imunoglobulina humana antirrábica</td><td>imunoglobulina humana antirrábica</td><td>Imunoglobulina</td><td/></tr><tr><td style=\"white-space:nowrap\">24<a name=\"BRImunobiologico-24\"> </a></td><td>SCR</td><td>vacina tríplice viral</td><td>vacina sarampo, caxumba, rubéola (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">25<a name=\"BRImunobiologico-25\"> </a></td><td>dT</td><td>vacina difteria e tétano adulto</td><td>vacina adsorvida difteria e tétano adulto</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">26<a name=\"BRImunobiologico-26\"> </a></td><td>VPC10</td><td>vacina pneumo 10</td><td>vacina pneumocócica 10-valente (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">27<a name=\"BRImunobiologico-27\"> </a></td><td>SALATRO</td><td>soro antilatrodéctico</td><td>soro antilatrodéctico (Latrodectus curacaviensis)</td><td>Soro</td><td/></tr><tr><td style=\"white-space:nowrap\">28<a name=\"BRImunobiologico-28\"> </a></td><td>VOPb</td><td>vacina oral poliomielite bivalente</td><td>vacina poliomielite 1 e 3 (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">29<a name=\"BRImunobiologico-29\"> </a></td><td>Penta acelular</td><td>vacina penta acelular (DTPa/VIP/Hib)</td><td>vacina adsorvida difteria, tétano, pertussis (acelular), poliomielite 1, 2 e 3 (inativada) e Haemophilus influenzae B (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">30<a name=\"BRImunobiologico-30\"> </a></td><td>FTp</td><td>vacina febre tifóide</td><td>vacina febre tifóide (polissacarídica)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">31<a name=\"BRImunobiologico-31\"> </a></td><td>SALOX</td><td>soro antiloxoscélico</td><td>soro antiloxoscélico (trivalente)</td><td>Soro</td><td/></tr><tr><td style=\"white-space:nowrap\">32<a name=\"BRImunobiologico-32\"> </a></td><td>SALON</td><td>soro antilonômico</td><td>soro antilonômico</td><td>Soro</td><td/></tr><tr><td style=\"white-space:nowrap\">33<a name=\"BRImunobiologico-33\"> </a></td><td>INF3</td><td>vacina influenza trivalente</td><td>vacina influenza trivalente (fragmentada, inativada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">34<a name=\"BRImunobiologico-34\"> </a></td><td>VZ</td><td>vacina varicela</td><td>vacina varicela (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">35<a name=\"BRImunobiologico-35\"> </a></td><td>HA virossomal</td><td>vacina hepatite A (virossomal)</td><td>vacina adsorvida hepatite A (virossomal)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">36<a name=\"BRImunobiologico-36\"> </a></td><td>SR</td><td>vacina dupla viral</td><td>vacina sarampo, rubéola (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">37<a name=\"BRImunobiologico-37\"> </a></td><td>VR</td><td>vacina raiva (inativada)</td><td>vacina raiva (inativada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">38<a name=\"BRImunobiologico-38\"> </a></td><td>SBOTULTRI</td><td>soro antibotulínico (trivalente)</td><td>soro antibotulínico (trivalente)</td><td>Soro</td><td/></tr><tr><td style=\"white-space:nowrap\">39<a name=\"BRImunobiologico-39\"> </a></td><td>Tetra</td><td>vacina DTP/Hib</td><td>vacina adsorvida difteria, tétano, pertussis e Haemophilus influenzae B (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">40<a name=\"BRImunobiologico-40\"> </a></td><td>VPC7</td><td>vacina pneumo 7</td><td>vacina pneumocócica 7-valente (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">41<a name=\"BRImunobiologico-41\"> </a></td><td>MenC</td><td>vacina meningo C</td><td>vacina meningocócica C (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">42<a name=\"BRImunobiologico-42\"> </a></td><td>Penta</td><td>vacina penta (DTP/HB/Hib)</td><td>vacina adsorvida difteria, tétano, pertussis, hepatite B (recombinante) e Haemophilus influenzae B (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">43<a name=\"BRImunobiologico-43\"> </a></td><td>Hexa acelular</td><td>vacina hexa acelular (DTPa/HB/VIP/Hib)</td><td>vacina adsorvida difteria, tétano, pertussis (acelular), hepatite B (recombinante), poliomielite 1, 2 e 3 (inativada), Haemophilus influenzae B (conjugada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">44<a name=\"BRImunobiologico-44\"> </a></td><td>INFH1N1-2009</td><td>vacina influenza A (H1N1) (inativada, fragmentada)</td><td>vacina influenza tipo A (H1N1) (inativada, fragmentada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">45<a name=\"BRImunobiologico-45\"> </a></td><td>ROTA</td><td>vacina rotavírus</td><td>vacina rotavírus humano G1P[8] (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">46<a name=\"BRImunobiologico-46\"> </a></td><td>DTP</td><td>vacina DTP</td><td>vacina adsorvida difteria, tétano e pertussis</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">47<a name=\"BRImunobiologico-47\"> </a></td><td>DTPa</td><td>vacina DTPa infantil</td><td>vacina adsorvida difteria, tétano e pertussis (acelular)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">48<a name=\"BRImunobiologico-48\"> </a></td><td>DILSCR</td><td>diluente para vacina tríplice viral</td><td>diluente para vacina sarampo, caxumba, rubéola (atenuada)</td><td>Diluente</td><td/></tr><tr><td style=\"white-space:nowrap\">49<a name=\"BRImunobiologico-49\"> </a></td><td>DILVFA</td><td>diluente para vacina febre amarela</td><td>diluente para vacina febre amarela (atenuada)</td><td>Diluente</td><td/></tr><tr><td style=\"white-space:nowrap\">50<a name=\"BRImunobiologico-50\"> </a></td><td>DILHib</td><td>diluente para vacina Hib</td><td>diluente para vacina Haemophilus influenzae B (conjugada)</td><td>Diluente</td><td/></tr><tr><td style=\"white-space:nowrap\">51<a name=\"BRImunobiologico-51\"> </a></td><td>Fta</td><td>vacina febre tifóide (atenuada)</td><td>vacina febre tifóide (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">52<a name=\"BRImunobiologico-52\"> </a></td><td>DILMenAC</td><td>diluente para vacina meningo AC</td><td>diluente para vacina meningocócica AC (polissacarídica)</td><td>Diluente</td><td/></tr><tr><td style=\"white-space:nowrap\">53<a name=\"BRImunobiologico-53\"> </a></td><td>DILSR</td><td>diluente para vacina dupla viral</td><td>diluente para vacina sarampo, rubéola (atenuada)</td><td>Diluente</td><td/></tr><tr><td style=\"white-space:nowrap\">54<a name=\"BRImunobiologico-54\"> </a></td><td>DILVAR</td><td>diluente para vacina varicela</td><td>diluente para vacina varicela (atenuada)</td><td>Diluente</td><td/></tr><tr><td style=\"white-space:nowrap\">55<a name=\"BRImunobiologico-55\"> </a></td><td>HAinf</td><td>vacina hepatite A infantil</td><td>vacina adsorvida hepatite A (inativada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">56<a name=\"BRImunobiologico-56\"> </a></td><td>SCRV</td><td>vacina tetraviral</td><td>vacina sarampo, caxumba, rubéola e varicela (atenuada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">57<a name=\"BRImunobiologico-57\"> </a></td><td>dTpa</td><td>vacina dTpa adulto</td><td>vacina adsorvida difteria, tétano e pertussis (acelular)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">58<a name=\"BRImunobiologico-58\"> </a></td><td>DTPa/VIP</td><td>vacina tetra acelular DTPa/VIP</td><td>vacina adsorvida difteria, tétano, pertussis (acelular), poliomielite 1, 2 e 3 (inativada)</td><td>Vacina</td><td/></tr><tr><td style=\"white-space:nowrap\">59<a name=\"BRImunobiologico-59\"> </a></td><td>VPC13</td><td>vacina pneumo 13</td><td>vacina pneumocócica 13-valente (conjugada)</td><td>Vacina</td><td/