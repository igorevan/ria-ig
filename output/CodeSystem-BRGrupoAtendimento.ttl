  fhir:CodeSystem.property [
     fhir:index 0 ;
     fhir:CodeSystem.property.code [ fhir:value "Category" ] ;
     fhir:CodeSystem.property.description [ fhir:value "Identifica a classificação macro do grupo de atendimento para a vacinação, agregando descrições específicas de indivíduos que compartilham características clínicas, epidemiológicas, ocupacionais, etárias ou sociais comuns, com o objetivo de padronizar registros, apoiar estratégias de imunização e viabilizar análises agregadas nos sistemas de informação em saúde." ] ;
     fhir:CodeSystem.property.type [ fhir:value "string" ]
  ], [
     fhir:index 1 ;
     fhir:CodeSystem.property.code [ fhir:value "inactive" ] ;
     fhir:CodeSystem.property.uri [ fhir:value "http://hl7.org/fhir/concept-properties#inactive" ] ;
     fhir:CodeSystem.property.description [ fhir:value "Status do Grupo de Atendimento em que determina se ele está apto para uso no registro de doses aplicadas. Serão aceitos códigos inativos apenas em caso de Transcrição de Caderneta." ] ;
     fhir:CodeSystem.property.type [ fhir:value "boolean" ]
  ] ;
